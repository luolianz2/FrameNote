<?xml version="1.0" encoding="utf-8"?>
<!-- 框记页布局 —— 拍照采集主界面 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".CaptureActivity">

    <!-- ===== 顶部栏：笔记本选择 + 搜索 ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:background="@color/surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 当前笔记本下拉选择器（外层样式，交互在后续迭代实现） -->
        <TextView
            android:id="@+id/tvNotebookSelector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/current_notebook"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawableEnd="@android:drawable/arrow_down_float"
            android:drawablePadding="4dp" />

        <!-- 搜索按钮（外层样式，交互在后续迭代实现） -->
        <TextView
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ===== 顶部分割线 ===== -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== 中间内容区：采集区列表 ===== -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintBottom_toTopOf="@id/fabCamera"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- 空状态提示：暂无采集内容 -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="80dp">

                <!-- 空状态图标（使用文字占位，后续可替换为图片） -->

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:alpha="0.3"
                    android:background="@drawable/ic_launcher_background"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/no_captures"
                    android:textColor="@color/textHint"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/no_captures_hint"
                    android:textColor="@color/textHint"
                    android:textSize="13sp"
                    android:alpha="0.7" />

            </LinearLayout>

            <!--
                采集区列表将在此处动态添加
                每个采集区包含：图片区域 + 文字区域
                后续迭代引入 RecyclerView 实现
            -->

        </LinearLayout>

    </ScrollView>

    <!-- ===== 拍照按钮（FAB） ===== -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/take_photo"
        android:src="@android:drawable/ic_menu_camera"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- ===== 底部分割线 ===== -->
    <View
        android:id="@+id/dividerBottom"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== 底部导航栏 ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 框记标签（当前选中） -->
        <TextView
            android:id="@+id/tabCapture"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_capture"
            android:textColor="@color/tabActive"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 笔记本标签 -->
        <TextView
            android:id="@+id/tabNotebook"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_notebook"
            android:textColor="@color/tabInactive"
            android:textSize="14sp" />

        <!-- 我的标签 -->
        <TextView
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_profile"
            android:textColor="@color/tabInactive"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
